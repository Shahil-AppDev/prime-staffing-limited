# DEMO Environment - Use for local development and client demos
# This is a working configuration for quick setup

# Database
DATABASE_URL="postgresql://postgres:Sha742445!!@localhost:5432/rajiv_platform?schema=public"

# Backend
BACKEND_PORT=4000
NODE_ENV=development
API_PREFIX=api

# JWT (Demo keys - CHANGE IN PRODUCTION)
JWT_SECRET="demo-jwt-secret-key-for-development-only-12345678"
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET="demo-refresh-secret-key-for-development-only-12345678"
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URLs
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# Cloudinary (Optional - leave empty for demo)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# n8n (Optional - leave empty for demo)
N8N_URL=http://localhost:5678
N8N_WEBHOOK_URL=http://localhost:5678/webhook
N8N_API_KEY=

# Social Media (Optional - leave empty for demo)
INSTAGRAM_ACCESS_TOKEN=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
TIKTOK_ACCESS_TOKEN=
PINTEREST_ACCESS_TOKEN=

# OpenAI (Optional - leave empty for demo)
OPENAI_API_KEY=

# Email (Optional - leave empty for demo)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@primestaffing.com

# Redis (Optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Security
BCRYPT_SALT_ROUNDS=10
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
