# Production Environment Variables Template
# Copy this to .env and fill in real values

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://postgres:STRONG_PASSWORD@postgres:5432/rajiv_platform?schema=public"
POSTGRES_PASSWORD="STRONG_PASSWORD_HERE"

# ============================================
# BACKEND API
# ============================================
NODE_ENV=production
BACKEND_PORT=4000
API_PREFIX=api

# ============================================
# JWT SECRETS (Generate with: openssl rand -base64 32)
# ============================================
JWT_SECRET="GENERATE_STRONG_SECRET_HERE"
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET="GENERATE_STRONG_REFRESH_SECRET_HERE"
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# FRONTEND URLS
# ============================================
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api
NEXT_PUBLIC_FRONTEND_URL=https://yourdomain.com
NEXT_PUBLIC_ADMIN_URL=https://admin.yourdomain.com

# ============================================
# CLOUDINARY (Media Storage)
# ============================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ============================================
# N8N AUTOMATION
# ============================================
N8N_URL=http://n8n:5678
N8N_WEBHOOK_URL=http://n8n:5678/webhook
N8N_API_KEY=your-n8n-api-key
N8N_HOST=n8n.yourdomain.com
N8N_USER=admin
N8N_PASSWORD=STRONG_PASSWORD

# ============================================
# SOCIAL MEDIA API KEYS
# ============================================
INSTAGRAM_ACCESS_TOKEN=your-instagram-token
FACEBOOK_ACCESS_TOKEN=your-facebook-token
FACEBOOK_PAGE_ID=your-page-id
TIKTOK_ACCESS_TOKEN=your-tiktok-token
PINTEREST_ACCESS_TOKEN=your-pinterest-token

# ============================================
# OPENAI (AI Features)
# ============================================
OPENAI_API_KEY=sk-your-openai-key

# ============================================
# EMAIL CONFIGURATION
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# ============================================
# REDIS (Optional - Caching)
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# SECURITY
# ============================================
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
CORS_ORIGIN=https://yourdomain.com,https://admin.yourdomain.com

# ============================================
# MONITORING (Optional)
# ============================================
SENTRY_DSN=your-sentry-dsn
